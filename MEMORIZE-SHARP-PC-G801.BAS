1 RANDOMIZE
10 PRINT "MEMORIZATION GAME BY AMIGOJAPAN FOR SHARP PC-G801"
20 LONG=0
30 COMPMEM$=""
40 LONG=LONG+1
50 FOR CHARS=1 TO LONG
60 COMPMEM$=COMPMEM$+STR$(INT((9*RND(1))+1))
70 NEXT CHARS
80 PRINT "MEMORIZE THIS:";COMPMEM$
85 FOR SLEEP=1 TO 2000
90 WAIT 255
100 NEXT SLEEP
120 CLS
130 PRINT "ENTER YOUR GUESS"
140 INPUT UI
145 USERINPUT$=STR$(UI)
150 PRINT COMPMEM$
160 IF COMPMEM$=USERINPUT$ GOTO 30
170 PRINT "YOUR SCORE:";LONG