10 REM SCENELIFE - CROSS-PLATFORM EDITION
20 REM ADDED: QUIT OPTION & SCORE SUMMARY
30 PRINT CHR$(147): REM CLEAR SCREEN
40 PRINT "SCENE LIFE - 8-BIT EDITION"
50 PRINT "-----------------------------------"
60 SK = 0: FA = 0: MO = 100: HE = 100: DA = 1: RE = 0

70 REM --- MAIN GAME LOOP ---
80 PRINT: PRINT "DAY:"; DA; " SK:"; SK; " FA:"; FA
90 PRINT "MONEY: $"; MO; " HEALTH:"; HE; "%"
100 PRINT "1)CODE 2)RELEASE 3)WORK 4)PARTY"
110 PRINT "5)SLEEP 6)QUIT"
120 INPUT "ACTION"; A

130 IF A = 1 THEN GOSUB 300: GOTO 200
140 IF A = 2 THEN GOSUB 400: GOTO 200
150 IF A = 3 THEN GOSUB 500: GOTO 200
160 IF A = 4 THEN GOSUB 600: GOTO 200
170 IF A = 5 THEN GOSUB 700: GOTO 200
180 IF A = 6 THEN GOTO 800 :REM EXIT TO SCORE SCREEN
190 PRINT "INVALID CHOICE": GOTO 100

200 REM --- END OF TURN ---
210 DA = DA + 1
220 IF HE <= 0 THEN PRINT "YOU BURNED OUT!": GOTO 800
230 IF MO < 0 THEN MO = 0
240 GOTO 80

300 REM --- CODE ---
310 PRINT "CODING..."
320 SI = INT(RND(1)*5)+1
330 SK = SK + SI: HE = HE - 5
340 RETURN

400 REM --- RELEASE ---
410 IF SK < 10 THEN PRINT "SKILL TOO LOW!": RETURN
420 PRINT "NEW RELEASE!"
430 FI = SK + INT(RND(1)*10)
440 FA = FA + FI: SK = SK - 5: MO = MO + INT(FA / 2)
450 RE = RE + 1
460 RETURN

500 REM --- WORK ---
510 PRINT "WORKING..."
520 MI = 20 + INT(RND(1)*30)
530 MO = MO + MI: HE = HE - 10
540 RETURN

600 REM --- PARTY ---
610 PRINT "PARTYING!"
620 HE = HE + 10: IF HE > 100 THEN HE = 100
630 MO = MO - 20: FA = FA + 2
640 RETURN

700 REM --- SLEEP ---
710 PRINT "SLEEPING..."
720 HE = HE + 25: IF HE > 100 THEN HE = 100
730 RETURN

800 REM --- FINAL SCORE SCREEN ---
810 PRINT CHR$(147)
820 PRINT "==================================="
830 PRINT "      FINAL SCENE STATISTICS"
840 PRINT "==================================="
850 PRINT "DAYS IN THE SCENE:"; DA
860 PRINT "TOTAL RELEASES   :"; RE
870 PRINT "FINAL FAME LEVEL :"; FA
880 PRINT "FINAL SKILL LEVEL:"; SK
890 PRINT "-----------------------------------"
900 IF RE > 5 THEN PRINT "STATUS: SCENE LEGEND!": END
910 PRINT "STATUS: UNKNOWN LAMER": END