10 PRINT "LUNAR LANDER SIMULATION"
20 LET H=100 : REM HEIGHT
30 LET V=30  : REM VELOCITY
40 LET F=200 : REM FUEL
50 PRINT "HEIGHT=";H
51 PRINT "VELOCITY=";V
52 PRINT "FUEL=";F
60 INPUT "FUEL BURN (0-20)";B
70 IF B>F THEN B=F
80 LET F=F-B
90 LET V=V+5-B*0.5 : REM GRAVITY MINUS THRUST
120 IF F>0 THEN 50
121 PRINT "OUT OF FUEL!"
122 LET H=H-V
123 IF H>=0 THEN 50
150 PRINT "LANDED. VELOCITY:";V
160 IF V<10 THEN PRINT "SAFE LANDING"
170 IF V>=10 THEN PRINT "CRASHED"
180 END