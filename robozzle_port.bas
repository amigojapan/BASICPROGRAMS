10 DIM G(10,10)
20 DIM PX(4),PY(4),PD(4)
30 DIM PR$(4)
40 PRINT CHR$(147)
50 LEVEL=1
10 REM ROBOZZLE BASIC PORT FOR CBM BASIC V2 / COMMANDER X16
20 PRINT CHR$(147)
40 FOR I=1 TO 4:PR$(I)="        ":NEXT I
50 LEVEL=1:MAXLV=30
60 GOSUB 1000
70 GOTO 200
200 GOSUB 2000
210 INPUT "COMMAND (RUN,EDIT,CLEAR,HELP,NEXT,QUIT)";A$
220 A$=LEFT$(A$,5)
230 IF A$="RUN" THEN GOSUB 5000:GOTO 200
240 IF A$="EDIT" THEN GOSUB 3000:GOTO 200
250 IF A$="CLEAR" THEN GOSUB 3500:GOTO 200
260 IF A$="HELP" THEN GOSUB 4000:GOTO 200
270 IF A$="NEXT" THEN LEVEL=LEVEL+1:IF LEVEL>MAXLV THEN LEVEL=1
280 IF A$="NEXT" THEN GOSUB 1000:GOTO 200
290 IF A$="QUIT" THEN END
300 GOTO 200
1000 REM LOAD LEVEL

1010 FOR Y=1 TO 5
1020 FOR X=1 TO 5
1030 G(Y,X)=0
1040 NEXT X
1050 NEXT Y

1060 IF LEVEL=1 THEN G(3,3)=2:PX(1)=3:PY(1)=4:PD(1)=0
1070 IF LEVEL=2 THEN G(2,3)=2:G(4,3)=2:PX(1)=3:PY(1)=5:PD(1)=0

1080 RETURN
1090 IF C$=">" THEN PX=X:PY=Y:PD=1:LV$(Y)=LEFT$(LV$(Y),X-1)+"."+MID$(LV$(Y),X+1)
1100 IF C$="V" THEN PX=X:PY=Y:PD=2:LV$(Y)=LEFT$(LV$(Y),X-1)+"."+MID$(LV$(Y),X+1)
1110 IF C$="<" THEN PX=X:PY=Y:PD=3:LV$(Y)=LEFT$(LV$(Y),X-1)+"."+MID$(LV$(Y),X+1)
1120 NEXT X
1130 NEXT Y
1140 FOR Y=1 TO 5:WK$(Y)=LV$(Y):NEXT Y
1150 GOSUB 1500
1160 RETURN
1500 REM COUNT STARS
1510 IF C$=">" THEN PD(1)=PD(1)+1:IF PD(1)>3 THEN PD(1)=0
1515 IF C$="<" THEN PD(1)=PD(1)-1:IF PD(1)<0 THEN PD(1)=3
1520 FOR Y=1 TO 5
1530 FOR X=1 TO 5
1540 C$=MID$(WK$(Y),X,1)
1550 IF C$="*" THEN STARC=STARC+1
1560 NEXT X
1570 NEXT Y
1580 RETURN
2000 REM DRAW
2010 PRINT CHR$(147)
2020 PRINT "ROBOZZLE BASIC"
2030 PRINT "LEVEL ";LEVEL;"/";MAXLV;"  STARS ";STARC
2040 PRINT
2050 PRINT "GRID"
2060 FOR Y=1 TO 5
2070 R$=""
2080 FOR X=1 TO 5
2090 C$=MID$(WK$(Y),X,1)
2100 IF X=PX AND Y=PY THEN GOSUB 2300:C$=P$
2110 R$=R$+C$
2120 NEXT X
2130 PRINT R$
2140 NEXT Y
2150 PRINT
2160 PRINT "F1:";PR$(1)
2170 PRINT "F2:";PR$(2)
2180 PRINT "F3:";PR$(3)
2190 PRINT "F4:";PR$(4)
2200 PRINT
2210 RETURN
2300 REM PLAYER CHAR
2310 IF PD=0 THEN P$="^":RETURN
2320 IF PD=1 THEN P$=">":RETURN
2330 IF PD=2 THEN P$="V":RETURN
2340 P$="<"
2350 RETURN
3000 REM EDIT ONE CELL
3010 INPUT "FUNCTION 1-4";F
3020 IF F<1 OR F>4 THEN RETURN
3030 INPUT "SLOT 1-8";S
3040 IF S<1 OR S>8 THEN RETURN
3050 INPUT "COMMAND";C$
3060 C$=LEFT$(C$,1)
3070 A$=PR$(F)
3080 PR$(F)=LEFT$(A$,S-1)+C$+MID$(A$,S+1)
3090 RETURN
3500 REM CLEAR ONE FUNCTION
3510 INPUT "FUNCTION 1-4";F
3520 IF F<1 OR F>4 THEN RETURN
3530 PR$(F)="        "
3540 RETURN
4000 REM HELP
4010 PRINT CHR$(147)
4020 PRINT "ROBOZZLE COMMANDS"
4030 PRINT
4040 PRINT "^  MOVE FORWARD"
4050 PRINT "<  TURN LEFT"
4060 PRINT ">  TURN RIGHT"
4070 PRINT "1-4 CALL F1-F4"
4080 PRINT
4090 PRINT "R MOVE ONLY ON RED"
4100 PRINT "G MOVE ONLY ON GREEN"
4110 PRINT "B MOVE ONLY ON BLUE"
4120 PRINT
4130 PRINT "L LEFT ONLY ON RED"
4140 PRINT "M LEFT ONLY ON GREEN"
4150 PRINT "N LEFT ONLY ON BLUE"
4160 PRINT
4170 PRINT "Y RIGHT ONLY ON RED"
4180 PRINT "U RIGHT ONLY ON GREEN"
4190 PRINT "Z RIGHT ONLY ON BLUE"
4200 PRINT
4210 PRINT "EDIT = CHANGE ONE CELL"
4220 PRINT "CLEAR = EMPTY FUNCTION"
4230 PRINT "RUN = PLAY CURRENT LEVEL"
4240 PRINT "NEXT = NEXT LEVEL"
4250 PRINT "QUIT = EXIT"
4260 INPUT "PRESS RETURN";A$
4270 RETURN
5000 REM RUN CURRENT LEVEL
5010 FOR Y=1 TO 5:WK$(Y)=LV$(Y):NEXT Y
5020 GOSUB 1500
5030 BAD=0
5040 IF NX<1 THEN GOSUB 9000:RETURN
5041 IF NX>5 THEN GOSUB 9000:RETURN
5042 IF NY<1 THEN GOSUB 9000:RETURN
5043 IF NY>5 THEN GOSUB 9000:RETURN
5050 ST=1:STF(1)=1:STP(1)=1
5060 GOSUB 2000
5070 IF ST<1 THEN PRINT "DONE":RETURN
5080 STEP=STEP+1:IF STEP>300 THEN PRINT "TOO MANY STEPS":RETURN
5090 F=STF(ST)
5100 P=STP(ST)
5110 C$=MID$(PR$(F),P,1)
5120 IF C$=" " THEN ST=ST-1:GOTO 5070
5130 STP(ST)=P+1
5140 T$=MID$(WK$(PY),PX,1)
5150 IF C$="^" THEN GOSUB 6000:GOTO 5600
5160 IF C$="<" THEN PD=PD-1:IF PD<0 THEN PD=3:GOTO 5600
5170 IF C$=">" THEN PD=PD+1:IF PD>3 THEN PD=0:GOTO 5600
5180 IF C$="1" THEN FN=1:GOSUB 7000:GOTO 5600
5190 IF C$="2" THEN FN=2:GOSUB 7000:GOTO 5600
5200 IF C$="3" THEN FN=3:GOSUB 7000:GOTO 5600
5210 IF C$="4" THEN FN=4:GOSUB 7000:GOTO 5600
5220 IF C$="R" THEN IF T$="r" THEN GOSUB 6000:GOTO 5600
5230 IF C$="G" THEN IF T$="g" THEN GOSUB 6000:GOTO 5600
5240 IF C$="B" THEN IF T$="b" THEN GOSUB 6000:GOTO 5600
5250 IF C$="L" THEN IF T$="r" THEN PD=PD-1:IF PD<0 THEN PD=3:GOTO 5600
5260 IF C$="M" THEN IF T$="g" THEN PD=PD-1:IF PD<0 THEN PD=3:GOTO 5600
5270 IF C$="N" THEN IF T$="b" THEN PD=PD-1:IF PD<0 THEN PD=3:GOTO 5600
5280 IF C$="Y" THEN IF T$="r" THEN PD=PD+1:IF PD>3 THEN PD=0:GOTO 5600
5290 IF C$="U" THEN IF T$="g" THEN PD=PD+1:IF PD>3 THEN PD=0:GOTO 5600
5300 IF C$="Z" THEN IF T$="b" THEN PD=PD+1:IF PD>3 THEN PD=0:GOTO 5600
5310 GOTO 5600
5600 GOSUB 2000
5610 IF BAD=1 THEN PRINT "CRASH":RETURN
5620 IF STARC=0 THEN GOTO 5700
5630 FOR D=1 TO 80:NEXT D
5640 GOTO 5070
5700 PRINT "SOLVED!"
5710 LEVEL=LEVEL+1:IF LEVEL>MAXLV THEN LEVEL=1
5720 GOSUB 1000
5730 RETURN
6000 REM MOVE FORWARD
6010 NX=PX:NY=PY
6020 IF PD=0 THEN NY=NY-1
6030 IF PD=1 THEN NX=NX+1
6040 IF PD=2 THEN NY=NY+1
6050 IF PD=3 THEN NX=NX-1
6060 IF NX<1 THEN BAD=1:RETURN
6070 IF NX>5 THEN BAD=1:RETURN
6080 IF NY<1 THEN BAD=1:RETURN
6090 IF NY>5 THEN BAD=1:RETURN
6100 PX=NX:PY=NY
6110 T$=MID$(WK$(PY),PX,1)
6120 IF T$<>"*" THEN RETURN
6130 A$=WK$(PY)
6140 WK$(PY)=LEFT$(A$,PX-1)+"."+MID$(A$,PX+1)
6150 STARC=STARC-1
6160 RETURN
7000 REM CALL FUNCTION IN FN
7010 ST=ST+1
7020 IF ST>20 THEN BAD=1:RETURN
7030 STF(ST)=FN
7040 STP(ST)=1
7050 RETURN

