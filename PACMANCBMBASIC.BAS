10 PRINT CHR$(147);
20 GOSUB 1000: REM INIT
30 GOSUB 2000: REM DRAW
40 PRINT "SCORE:"; SC; " LIVES:"; LI; " POWER:"; PM; "   "
50 IF TE=0 THEN PRINT "YOU WIN!": END
60 IF LI=0 THEN PRINT "GAME OVER!": END
70 GET A$: IF A$="" THEN 70
80 DX=0: DY=0: IF A$="W" OR A$="w" THEN DY=-1: P$="^"
90 IF A$="S" OR A$="s" THEN DY=1: P$="V"
100 IF A$="A" OR A$="a" THEN DX=-1: P$="<"
110 IF A$="D" OR A$="d" THEN DX=1: P$=">"
120 IF DX=0 AND DY=0 THEN 70
130 NX=PX+DX: NY=PY+DY
140 IF B(NX,NY)=1 THEN 70: REM BONK
150 PX=NX: PY=NY
160 IF B(PX,PY)=2 THEN SC=SC+10: B(PX,PY)=0: TE=TE-1
170 IF B(PX,PY)=3 THEN SC=SC+50: B(PX,PY)=0: TE=TE-1: PM=10
180 GOSUB 4000: REM CHECK COL
190 GOSUB 3000: REM MOVE GHOSTS
200 GOSUB 4000: REM CHECK COL
210 IF PM>0 THEN PM=PM-1
220 GOTO 30
1000 DIM B(18,13), GX(2), GY(2)
1010 SC=0: LI=3: PM=0: TE=0: P$="^"
1020 RESTORE
1030 FOR Y=0 TO 13
1040 READ R$
1050 FOR X=0 TO 18
1060 C$=MID$(R$,X+1,1)
1070 IF C$="#" THEN B(X,Y)=1
1080 IF C$="o" THEN B(X,Y)=2: TE=TE+1
1090 IF C$="X" THEN B(X,Y)=3: TE=TE+1
1100 IF C$=" " THEN B(X,Y)=0
1110 IF C$="^" THEN PX=X: PY=Y: B(X,Y)=0
1120 IF C$="M" THEN GX(1)=X: GY(1)=Y: B(X,Y)=0
1130 IF C$="W" THEN GX(2)=X: GY(2)=Y: B(X,Y)=0
1140 NEXT X: NEXT Y
1150 RETURN
2000 PRINT CHR$(19);
2010 FOR Y=0 TO 13
2020 FOR X=0 TO 18
2030 C=B(X,Y): C$=" "
2040 IF C=1 THEN C$=CHR$(160)
2050 IF C=2 THEN C$="o"
2060 IF C=3 THEN C$="X"
2070 IF X=PX AND Y=PY THEN C$=P$
2080 IF X=GX(1) AND Y=GY(1) THEN C$="M"
2090 IF X=GX(2) AND Y=GY(2) THEN C$="W"
2100 PRINT C$;
2110 NEXT X
2120 PRINT ""
2130 NEXT Y
2140 RETURN
3000 FOR I=1 TO 2
3010 BD=-1: IF PM=0 AND I=2 THEN BD=999
3020 BX=GX(I): BY=GY(I): V=0: N=0
3030 FOR D=1 TO 4
3040 CX=0: CY=0: IF D=1 THEN CY=-1
3050 IF D=2 THEN CY=1
3060 IF D=3 THEN CX=-1
3070 IF D=4 THEN CX=1
3080 TX=GX(I)+CX: TY=GY(I)+CY
3090 IF TX<0 OR TX>18 OR TY<0 OR TY>13 THEN 3160
3100 IF B(TX,TY)=1 THEN 3160
3110 V=1: MD=ABS(TX-PX)+ABS(TY-PY)
3120 IF PM>0 AND MD>BD THEN BD=MD: BX=TX: BY=TY
3130 IF PM>0 THEN 3160
3140 IF I=2 AND MD<BD THEN BD=MD: BX=TX: BY=TY
3150 IF I=1 THEN N=N+1: IF RND(1)<(1/N) THEN BX=TX: BY=TY
3160 NEXT D
3170 IF V=1 THEN GX(I)=BX: GY(I)=BY
3180 NEXT I
3190 RETURN
4000 FOR I=1 TO 2
4010 IF PX<>GX(I) OR PY<>GY(I) THEN 4060
4020 IF PM>0 THEN SC=SC+200: GX(I)=1: GY(I)=10: GOTO 4060
4030 LI=LI-1: PX=1: PY=1: P$="^"
4040 FOR J=1 TO 1000: NEXT J
4060 NEXT I
4070 RETURN
