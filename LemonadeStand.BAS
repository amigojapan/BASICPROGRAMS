10 PRINT "*** LEMONADE STAND ***"
20 PRINT "YOU HAVE $5.00 AND 10 DAYS."
30 D=1 : M=5.00
40 IF D > 10 THEN GOTO 200
50 F = INT(RND(1)*40) + 60 : C = INT((F - 32) * 5 / 9)
60 PRINT : PRINT "--- DAY";D;"---"
70 PRINT "FORECAST: ";F;"F (";C;"C)"
80 INPUT "PRICE PER GLASS (CENTS)";P
90 INPUT "GLASSES TO MAKE";G
100 INPUT "NUMBER OF ADVERTISEMENTS ($0.15 EA)";A
110 EX = (G * 0.05) + (A * 0.15)
120 IF EX > M THEN PRINT "NOT ENOUGH CASH!":GOTO 80
130 S = INT((F - P + (A * 10)) * (G / 10) * RND(1))
140 IF S < 0 THEN S = 0
150 IF S > G THEN S = G
160 R = S * (P / 100) : PR = R - EX : M = M + PR
170 PRINT "--- DAILY REPORT ---"
180 PRINT "TOTAL SOLD:";S;"GLASSES"
190 PRINT "INCOME: $";R;" COST: $";EX
200 IF PR >= 0 THEN PRINT "DAILY PROFIT: $";PR : GOTO 220
210 PRINT "DAILY LOSS: $";ABS(PR)
220 PRINT "CURRENT ASSETS: $";M
230 D = D + 1 : GOTO 40
300 PRINT : PRINT "GAME OVER!"
310 PRINT "FINAL ASSETS: $";M
320 IF M > 5 THEN PRINT "TOTAL PROFIT: $";M-5 : END
330 PRINT "TOTAL LOSS: $";5-M
