10 PRINT "ROBOZZEL LOADING..."
20 FOR I = 1 TO 10
30 PRINT "LOADING ROBOTS "; I
40 NEXT I
50 GOTO 10
60 PRINT "ROBOZZEL READY."
70 _GOTO 1000
1000 PRINT "COMMAND:"
1010 INPUT A
1020 IF A = "START" THEN GOSUB 2000
1030 IF A = "STOP" THEN GOSUB 3000
1040 GOTO 1000
2000 PRINT "ROBOZZEL STARTED!"
2010 RETURN
3000 PRINT "ROBOZZEL STOPPED!"
3010 RETURN
