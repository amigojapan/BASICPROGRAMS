10 REM SCENELIFE MOD FOR X16
20 REM FIXED FOR X16 BASIC SYNTAX
30 CLS: COLOR 1,0: PRINT "SCENE LIFE - COMMANDER X16 EDITION"
40 PRINT "-----------------------------------"
50 SK = 0: FA = 0: MO = 100: HE = 100: DR = 0
60 DA = 1

70 REM --- MAIN GAME LOOP ---
80 PRINT: PRINT "DAY:"; DA; " | SKILL:"; SK; " | FAME:"; FA
90 PRINT "MONEY: $"; MO; " | HEALTH:"; HE; "%"
100 PRINT "1)CODE  2)RELEASE  3)WORK  4)PARTY  5)SLEEP"
110 INPUT "ACTION"; A

120 IF A = 1 THEN GOSUB 300: GOTO 200
130 IF A = 2 THEN GOSUB 400: GOTO 200
140 IF A = 3 THEN GOSUB 500: GOTO 200
150 IF A = 4 THEN GOSUB 600: GOTO 200
160 IF A = 5 THEN GOSUB 700: GOTO 200
170 PRINT "INVALID": GOTO 100

200 REM --- END OF TURN ---
210 DA = DA + 1
220 IF HE <= 0 THEN PRINT "BURNED OUT!": END
230 IF MO < 0 THEN MO = 0
240 GOTO 80

300 REM --- CODE ---
310 PRINT "CODING..."
320 SI = INT(RND(1)*5)+1
330 SK = SK + SI: HE = HE - 5
340 RETURN

400 REM --- RELEASE ---
410 IF SK < 10 THEN PRINT "SKILL TOO LOW!": RETURN
420 PRINT "NEW RELEASE!"
430 FI = SK + INT(RND(1)*10)
440 FA = FA + FI: SK = SK - 5: MO = MO + (FA / 2)
450 RETURN

500 REM --- WORK ---
510 PRINT "WORKING..."
520 MI = 20 + INT(RND(1)*30)
530 MO = MO + MI: HE = HE - 10
540 RETURN

600 REM --- PARTY ---
610 PRINT "PARTYING!"
620 HE = HE + 10: IF HE > 100 THEN HE = 100
630 MO = MO - 20: FA = FA + 2
640 RETURN

700 REM --- SLEEP ---
710 PRINT "SLEEPING..."
720 HE = HE + 25: IF HE > 100 THEN HE = 100
730 RETURN